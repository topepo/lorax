{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(air:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git checkout:*)",
      "Bash(git grep:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mv:*)",
      "Bash(pkill:*)",
      "Bash(R:*)",
      "Bash(rm:*)",
      "Bash(Rscript:*)",
      "Bash(sed:*)",
      "Bash(sleep:*)",
      "Bash(tail:*)",
      "Bash(timeout:*)",
      "Bash(wc:*)",
      "Edit(R/*.R)",
      "Edit(tests/testthat/*.R)",
      "Edit(tests/testthat/_snaps/*.md)",
      "Edit(NEWS.md)",
      "Edit(DESCRIPTION)",
      "Edit(_pkgdown.yml)",
      "Read(R/*.R)",
      "Read(tests/testthat/*.R)",
      "Read(tests/testthat/_snaps/*.md)",
      "Read(tests/testthat/helper-*.R)",
      "Read(inst/*)",
      "Read(NEWS.md)",
      "Read(DESCRIPTION)",
      "Read(NAMESPACE)",
      "Read(man/*.Rd)",
      "Read(_pkgdown.yml)",
      "Skill",
      "WebFetch(domain:cran.r-project.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Write(R/*.R)",
      "Write(tests/testthat/*.R)",
      "Write(tests/testthat/_snaps/*.md)"
    ],
    "deny": [
      "Read(.Renviron)",
      "Read(.env)"
    ]
  }
}
